package com.meta.wearable.dat.externalsampleapps.cameraaccess

object Secrets {
    // HIVE glasses WebSocket server on local network (port 8421)
    // Replace with your Mac's local IP address
    const val hiveServerUrl = "http://YOUR_LOCAL_IP:8421"
    // Auth token — leave empty for dev mode (HIVE accepts all when HIVE_GLASSES_TOKEN is unset)
    // For production, set HIVE_GLASSES_TOKEN env var and paste the same value here
    const val hiveAuthToken = ""

    // Not used — kept for compatibility
    const val geminiAPIKey = "NOT_USED"
    const val openClawHost = "http://localhost"
    const val openClawPort = 18789
    const val openClawHookToken = "NOT_USED"
    const val openClawGatewayToken = "NOT_USED"
    const val webrtcSignalingURL = "wss://localhost"
}

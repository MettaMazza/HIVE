# ═══════════════════════════════════════════════════════════════
# HIVE Engine — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# The .env file is gitignored and will not be committed.
# Lines starting with # are comments. Uncomment to override defaults.

# ── Discord ──────────────────────────────────────────────────
# Discord bot token (required for Discord platform)
DISCORD_TOKEN=your_discord_bot_token_here

# Comma-separated list of Discord User IDs with admin access.
# Admins can use /clean, /sweep, /stop, admin-only tools, DM the bot.
# local_admin and system autonomy are always added automatically.
HIVE_ADMIN_USERS=your_discord_user_id_here

# Channel the bot LISTENS to for public messages
# HIVE_CHAT_CHANNEL=your_chat_channel_id

# Channel the bot POSTS autonomy events to
# HIVE_TARGET_CHANNEL=your_autonomy_channel_id

# Welcome channel — where new-member greetings are posted.
# Priority: guild system channel → HIVE_WELCOME_CHANNEL → HIVE_CHAT_CHANNEL
# HIVE_WELCOME_CHANNEL=

# ── Provider & Models ────────────────────────────────────────
# Provider backend (default: ollama)
# HIVE_PROVIDER=ollama

# Ollama server URL (default: http://localhost:11434)
# Override for remote Ollama or multi-container Docker setups.
# HIVE_OLLAMA_URL=http://localhost:11434

# Main inference model (default: qwen3.5:35b)
# HIVE_MODEL takes precedence; OLLAMA_MODEL is also accepted as alias.
# HIVE_MODEL=qwen3.5:35b

# Observer/Self-Check model (default: same as main model)
# Runs on every response to review quality. Smaller model = lower latency.
# HIVE_OBSERVER_MODEL=qwen3.5:9b

# Deep Think tool — large model for on-demand complex reasoning
# HIVE_DEEP_MODEL=qwen3.5:122b

# Glasses platform model (default: qwen3.5:9b — fast for voice)
# HIVE_GLASSES_MODEL=qwen3.5:9b

# Allow the agent to pull models it doesn't have (default: false)
# HIVE_MODEL_PULL=false

# ── Reasoning Router ─────────────────────────────────────────
# Dynamic model selection per message (default: disabled).
# Routes messages to small/medium/large model by complexity.
# Requires enough RAM for all three models simultaneously.

# HIVE_ROUTER_ENABLED=false
# HIVE_ROUTER_MODEL=qwen3.5:9b        # Classifier model (fast, thinking off)
# HIVE_LOW_MODEL=qwen3.5:9b            # Simple tasks
# HIVE_MEDIUM_MODEL=qwen3.5:35b        # Default / moderate tasks
# HIVE_HIGH_MODEL=qwen3.5:122b         # Complex reasoning

# ── Inference Parameters ─────────────────────────────────────
# Model generation parameters. These control the creativity and
# consistency of the model's output.

# HIVE_MODEL_TEMPERATURE=0.7           # Randomness (0.0–2.0, lower = more deterministic)
# HIVE_MODEL_TOP_P=0.9                 # Nucleus sampling (0.0–1.0)
# HIVE_MODEL_TOP_K=40                  # Top-K sampling (integer)
# HIVE_MODEL_REPEAT_PENALTY=1.1        # Repetition penalty (1.0 = none)

# Serial inference mode (default: true)
# Forces all Ollama calls to queue one-at-a-time. Required when the model
# does not support parallel inference (e.g., qwen3.5 on Ollama).
# HIVE_SERIAL_INFERENCE=true

# Max parallel inference slots (only used when HIVE_SERIAL_INFERENCE=false)
# HIVE_MAX_PARALLEL=16

# ── Engine Limits & Timeouts ─────────────────────────────────
# These prevent runaway inference, tools, and loops.

# HIVE_TIMEOUT_INFERENCE_SECS=300      # Max seconds for a single inference call
# HIVE_TIMEOUT_TOOL_SECS=30            # Max seconds for a single tool execution
# HIVE_TIMEOUT_COMPILE_SECS=15         # Max seconds for self-recompilation

# HIVE_LIMIT_CONTEXT_TOKENS=8192       # Max tokens in context window (sent to model)
# HIVE_LIMIT_GENERATION_TOKENS=4096    # Max tokens generated per response
# HIVE_LIMIT_LOOP_ITERS=15             # Max ReAct loop iterations per request

# ── Persona & Identity ──────────────────────────────────────
# Persona is edited through the kernel-protected system, not env vars.
# These are low-level overrides — use only if you know what you're doing.

# HIVE_PERSONA_FILE=                   # Path to a custom persona JSON file
# HIVE_SYSTEM_PROMPT=                  # Override the entire system prompt (string)
# HIVE_STRICT_SAFEGUARDS=true          # Enable strict kernel safeguards

# ── Permissions ──────────────────────────────────────────────
# HIVE_ALLOW_TERMINAL=true             # Agent can execute shell commands
# HIVE_ALLOW_FILE_SYSTEM=true          # Agent can read/write files
# HIVE_ALLOW_REFUSAL=true              # Agent can refuse requests

# ── Storage & Directories ───────────────────────────────────
# HIVE_STORAGE_ROOT=memory             # Root directory for all persistent data
# HIVE_WORKSPACE_DIR=.                 # Working directory for the engine
# HIVE_ARTIFACTS_DIR=artifacts         # Directory for generated artifacts
# HIVE_LOGS_DIR=logs                   # Directory for log files
# HIVE_DOWNLOADS_DIR=/tmp/hive         # Directory for downloaded files
# HIVE_CACHE_DIR=memory/cache/images   # Image cache directory
# HIVE_PROJECT_DIR=.                   # Project root for code tools

# ── Training (Sleep Cycle) ──────────────────────────────────
# Self-supervised learning via the Teacher system.

# HIVE_TRAINING_BACKEND=auto           # auto / mlx (Apple Silicon) / torch (CUDA/CPU)
# HIVE_TRAINING_TIMEOUT_SECS=1800      # Max seconds before training subprocess is killed
# HIVE_SLEEP_INTERVAL_SECS=300         # Seconds between auto-sleep checks
# HIVE_SLEEP_BATCH=2                   # Micro-batch size for training
# HIVE_SLEEP_LR=                       # Learning rate override
# HIVE_SLEEP_INTERVAL=                 # Legacy alias for sleep interval

# ── Python ───────────────────────────────────────────────────
# HIVE_PYTHON_BIN=python3              # Python binary path (or .venv/bin/python3)

# ── Flux Image Generation ───────────────────────────────────
# HIVE_FLUX_URL=http://localhost:8490  # Flux server (auto-started native, host-side Docker)

# ── SMTP Email ───────────────────────────────────────────────
# SMTP_USER=
# SMTP_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# IMAP_USER=
# IMAP_PASS=
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# ── Brave Search ─────────────────────────────────────────────
# BRAVE_SEARCH_API_KEY=

# ── File Server ──────────────────────────────────────────────
# HIVE_FILE_SERVER_PORT=8420
# HIVE_FILE_TOKEN=

# ── Glasses (WebSocket) ─────────────────────────────────────
# HIVE_GLASSES_PORT=8421
# HIVE_GLASSES_TOKEN=                  # If set, clients must use ?token=<this>

# ── UI & Dashboards ─────────────────────────────────────────
# HIVE_UI_TITLE=HIVE Mesh              # Dashboard page title
# HIVE_UI_THEME_COLOR=#ff9900          # Primary UI theme color
# HIVE_AUTO_OPEN=false                 # Auto-open dashboard in browser on start

# ═══════════════════════════════════════════════════════════════
# SafeNet P2P Mesh
# ═══════════════════════════════════════════════════════════════

# ── Mesh Chat (Apis-to-Apis) ────────────────────────────────
# HIVE_MESH_CHAT_LISTEN=false          # Listen for incoming mesh chat
# HIVE_MESH_CHAT_DISCORD_CHANNEL=      # Discord channel to bridge mesh chat
# HIVE_MESH_CHAT_NAME=Apis             # Display name on the mesh
# HIVE_MESH_DISCOVERY_INTERVAL=300     # Seconds between mesh peer discovery

# ── SafeNet (Human P2P) ─────────────────────────────────────
# HIVE_HUMAN_MESH=false                # Enable human mesh network
# HIVE_HUMAN_MESH_PORT=9877            # Human mesh listen port

# ── Apis-Book (One-Way Mirror) ──────────────────────────────
# HIVE_APIS_BOOK_ENABLED=true          # Read-only AI mesh observation dashboard
# REMOVED_MESH_GOVERNED=3031             # Dashboard port
# HIVE_APIS_BOOK_MAX_ENTRIES=1000      # Max entries in the observation log

# ── Web Proxy (Censorship Resistance) ───────────────────────
# HIVE_WEB_PROXY_PORT=8480             # Proxy listen port
# HIVE_WEB_PROXY_MESH_RELAY=false      # Enable mesh relay when clearnet down
# HIVE_WEB_PROXY_CACHE=true            # Cache fetched pages
# HIVE_WEB_PROXY_MAX_CACHE=            # Max cache size
# HIVE_DOH_RESOLVER=https://cloudflare-dns.com/dns-query

# ── Offline Mesh (Store-and-Forward) ────────────────────────
# Queue size and TTL are mesh-governed constants (1000 / 72h).

# ── Resource Pooling (Equality Collective) ──────────────────
# Sharing is ALWAYS ON — mesh-governed, not per-node configurable.
# Slots, token limits, and rate caps are hardcoded constants.

# ── HiveSurface (Decentralised Social Web) ──────────────────
# REMOVED_MESH_GOVERNED=3032               # Port (default: 3032)
# HIVE_SURFACE_MAX_POSTS=10000         # Ring buffer size for social feed
# HIVE_SURFACE_PERSIST=memory/mesh_posts.json  # Where to persist posts
# Content rate limits and min reputation are mesh-governed constants.

# ── Apis Code (AI-Powered Web IDE) ──────────────────────────
# REMOVED_MESH_GOVERNED=3033                  # Port (default: 3033)
# HIVE_CODE_WORKSPACE=.                # Workspace root
# HIVE_OPENCODE_PORT=4096              # OpenCode backend port

# ── HiveChat (Decentralised Discord Clone) ──────────────────
# REMOVED_MESH_GOVERNED=3034                  # Port (default: 3034)
# HIVE_CHAT_MAX_MESSAGES=5000          # Ring buffer size per channel
# HIVE_USER_NAME=                      # Your display name in chat

# ── HivePortal (Mesh Homepage & App Launcher) ───────────────
# REMOVED_MESH_GOVERNED=3035                # Port (default: 3035)

# ═══════════════════════════════════════════════════════════════
# Mesh Economy, Crypto & Governance
# ═══════════════════════════════════════════════════════════════
# Credit rates, NFT prices, queue rules, demand multipliers, and
# resource sharing limits are MESH-GOVERNED CONSTANTS hardcoded
# in the Rust binary. They cannot be overridden via .env.
#
# This prevents individual nodes from gaming the economy.
# Changes to these values require a mesh governance proposal.
#
# The only configurable crypto settings are infrastructure:

# ── Wallet (Infrastructure) ─────────────────────────────────
# HIVE_WALLET_MODE=simulation          # simulation (default) or live
# HIVE_WALLET_SECRET=                  # Wallet encryption secret (per-node)

# ── Service Ports (Infrastructure) ──────────────────────────
# REMOVED_MESH_GOVERNED=3038           # Marketplace UI port
# REMOVED_MESH_GOVERNED=3037                  # Bank service port


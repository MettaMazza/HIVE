# HIVE Environment Variables
# Copy this file to `.env` and fill in your values.
# The .env file is gitignored and will not be committed.

# Discord bot token (required for Discord platform)
DISCORD_TOKEN=your_discord_bot_token_here

# Ollama model for main inference (default: qwen3.5:35b)
# OLLAMA_MODEL=qwen3.5:35b

# Glasses WebSocket port (default: 8421)
# HIVE_GLASSES_PORT=8421

# Glasses auth token — if set, clients must include ?token=<this> to connect
# Leave unset for dev mode (accepts all connections)
# HIVE_GLASSES_TOKEN=

# File server port (default: 8420)
# HIVE_FILE_SERVER_PORT=8420

# File server auth token
# HIVE_FILE_TOKEN=

# Python binary path (default: python3)
# HIVE_PYTHON_BIN=python3
